# ═══════════════════════════════════════
# Acadexa Backend V2 — Environment
# ═══════════════════════════════════════
# انسخ الملف ده وسميه .env وغيّر القيم

# ── Environment
ENVIRONMENT=development

# ── Security
SECRET_KEY=acadexa-v2-secret-change-in-production-2026

# ── Server
HOST=0.0.0.0
PORT=8000

# ── Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Logging
LOG_LEVEL=INFO

# ── File limits
MAX_FILE_SIZE=52428800

# ── Concurrency
MAX_CONCURRENT_JOBS=5

# ── Job Retention (hours)
RESULT_RETENTION_HOURS=24

# ── Redis (optional)
REDIS_URL=
