# ===== File: python_backend/.env.example =====
# انسخ الملف ده وسميه .env وغيّر القيم

# ── Environment
ENVIRONMENT=development

# ── Security (غيّر ده في production)
SECRET_KEY=acadexa-secret-key-change-in-production-2024

# ── Server (Railway بيضيف PORT تلقائياً)
HOST=0.0.0.0
PORT=8000

# ── Logging
LOG_LEVEL=INFO

# ── File limits
MAX_FILE_SIZE=52428800

# ── Concurrency
MAX_CONCURRENT_JOBS=5

# ── Retention
RESULT_RETENTION_HOURS=24
