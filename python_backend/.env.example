# Acadexa Backend Configuration

# Environment
ENVIRONMENT=development  # development or production

# Security
SECRET_KEY=acadexa-super-secret-key-change-in-production-2024
ALLOWED_ORIGINS=*

# API Configuration
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# File Settings
MAX_FILE_SIZE=52428800  # 50MB
ALLOWED_EXTENSIONS=.xlsx,.xls

# Performance
MAX_CONCURRENT_JOBS=5
RESULT_RETENTION_HOURS=24

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_PERIOD=60